# ═══════════════════════════════════════════════════════════════════════════════
# INTENTIONAL CONNECTION — BACKEND ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
#
# SETUP INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your values for your environment (local, Render, Railway, VPS…)
#   3. Never commit .env to version control — it is in .gitignore
#
# CHANGING ENVIRONMENTS:
#   To deploy to a new domain, server, or hosting provider:
#   → Update only the values in .env
#   → Restart the server
#   → No source code changes are required
#
# ═══════════════════════════════════════════════════════════════════════════════


# ── Server ────────────────────────────────────────────────────────────────────

# Port the Express server listens on.
# Render, Railway, and Heroku automatically inject PORT — leave this as 3435 locally.
PORT=3435

# Runtime environment. Controls SSL defaults, logging verbosity, and error detail.
# Values: development | staging | production
NODE_ENV=development


# ── URLs ──────────────────────────────────────────────────────────────────────

# Public URL of the frontend application.
# Used for: password reset email links, OAuth redirects, CORS fallback.
#
# Local development:
FRONTEND_URL=http://localhost:5173
# Production example:
# FRONTEND_URL=https://app.intentionalconnections.com

# Alias for FRONTEND_URL — used by some third-party SDKs / services.
# If not set, defaults to the value of FRONTEND_URL above.
CLIENT_URL=http://localhost:5173
# CLIENT_URL=https://app.intentionalconnections.com

# Public URL of this backend service.
# Used for: self-referencing callbacks, LinkedIn redirect URI base, logging.
#
# Local development:
BACKEND_URL=http://localhost:3435
# Production example (Render):
# BACKEND_URL=https://your-app.onrender.com
# Production example (custom domain):
# BACKEND_URL=https://api.intentionalconnections.com

# Full API base path. Typically BACKEND_URL + /api
# Used for: client-side API config documentation, health check references.
API_BASE_URL=http://localhost:3435/api
# API_BASE_URL=https://api.intentionalconnections.com/api


# ── CORS ──────────────────────────────────────────────────────────────────────

# Comma-separated list of frontend origins allowed to call this backend.
# Applied to both Express cors() middleware and Socket.IO CORS.
#
# Rules:
#   • No trailing slashes on origins
#   • Include protocol (http:// or https://)
#   • Separate multiple origins with a comma and NO spaces
#   • Set to * to allow all origins (development only — insecure in production)
#
# Local development (single origin):
CORS_ALLOWED_ORIGINS=http://localhost:5173
#
# Staging (multiple origins):
# CORS_ALLOWED_ORIGINS=http://localhost:5173,https://staging.intentionalconnections.com
#
# Production (multiple origins):
# CORS_ALLOWED_ORIGINS=https://app.intentionalconnections.com,https://admin.intentionalconnections.com
#
# ⚠️  WARNING: Never use * in production — it disables credential security.


# ── Allowed Hosts ─────────────────────────────────────────────────────────────

# Comma-separated list of valid Host header values accepted by this backend.
# Used for reverse-proxy validation and host-based routing.
#
# Local development:
ALLOWED_HOSTS=localhost,127.0.0.1
#
# Production example:
# ALLOWED_HOSTS=api.intentionalconnections.com,your-app.onrender.com


# ── Database ──────────────────────────────────────────────────────────────────

# Full PostgreSQL connection string.
# SSL is enabled automatically for non-local connections (cloud hosting).
#
# Local PostgreSQL:
DATABASE_URL=postgresql://username:password@localhost:5432/database_name
#
# Supabase (cloud):
# DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres
#
# Render Postgres:
# DATABASE_URL=postgresql://user:password@host.render.com:5432/dbname


# ── JWT Authentication ────────────────────────────────────────────────────────

# Secret keys for signing JWT tokens. Use long, random strings (32+ characters).
# ⚠️  Never share or commit these values.
ACCESS_SECRET_KEY=your_access_token_secret_key_here_min_32_chars
REFRESH_SECRET_KEY=your_refresh_token_secret_key_here_min_32_chars
JWT_SECRET=your_jwt_password_reset_secret_key_here_min_32_chars


# ── Cloudinary (Image Uploads) ────────────────────────────────────────────────

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret


# ── LinkedIn OAuth ────────────────────────────────────────────────────────────

# Obtain from: https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# Must match EXACTLY what is registered in the LinkedIn Developer Console.
# Local development:
LINKEDIN_REDIRECT_URI=http://localhost:3435/api/linkedin/callback
# Production example:
# LINKEDIN_REDIRECT_URI=https://api.intentionalconnections.com/api/linkedin/callback


# ── Stripe (Payments) ────────────────────────────────────────────────────────

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret


# ── Google Gemini AI ──────────────────────────────────────────────────────────

GEMINI_API_KEY=your_google_gemini_api_key


# ── Email (Resend) ────────────────────────────────────────────────────────────

RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@yourdomain.com


# ── Feature Flags ─────────────────────────────────────────────────────────────

# Enable or disable the sentiment audit feature.
# Set to true to activate; false to disable.
ENABLE_SENTIMENT_AUDIT=false
